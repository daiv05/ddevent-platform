# Shared local environment
NODE_ENV=development
LOG_LEVEL=info
WEBHOOK_TIMEOUT_MS=8000
WEBHOOK_SIGNING_SECRET=change-me-local-secret

# Infrastructure
DATABASE_URL=postgresql://devent:devent@localhost:5432/devent?schema=public
REDIS_URL=redis://localhost:6379

# Services
API_PORT=3001
DASHBOARD_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
DEVENT_API_URL_SERVER=http://api:3001/v1
DEVENT_DASHBOARD_API_KEY=change-me-local-secret
